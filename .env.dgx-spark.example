# Project Chimera DGX Spark / GB10 ARM64 example environment
#
# Copy to .env.dgx-spark locally if useful, but do not commit real secrets.

# NVIDIA NGC PyTorch image used by services/sentiment-agent/Dockerfile.dgx.
CHIMERA_DGX_PYTORCH_IMAGE=nvcr.io/nvidia/pytorch:25.11-py3

# Host directory for Hugging Face / sentiment model cache.
CHIMERA_DGX_MODEL_CACHE=./models/dgx-spark/sentiment

# Optional local LLM endpoint, for example a DGX-hosted OpenAI-compatible server.
CHIMERA_DGX_LOCAL_LLM_ENABLED=true
CHIMERA_DGX_LLM_URL=http://host.docker.internal:8012
CHIMERA_DGX_LLM_MODEL=nemotron-3-super-120b-a12b-nvfp4
CHIMERA_DGX_LLM_TIMEOUT=300

# Optional external GLM key. Leave blank unless intentionally testing GLM.
GLM_API_KEY=

# Kimi K2.6 Super-Agent Configuration
KIMI_MODEL_NAME=moonshotai/Kimi-K2.6
KIMI_VLLM_ENDPOINT=http://kimi-vllm:8012
KIMI_MAX_TOKENS=32768
KIMI_TEMPERATURE=0.7
KIMI_TOP_P=0.9
KIMI_TIMEOUT_SECONDS=300

# gRPC Configuration
KIMI_GRPC_HOST=0.0.0.0
KIMI_GRPC_PORT=50052
NEMO_CLAW_GRPC_ENDPOINT=nemoclaw-orchestrator:50051

# Memory Configuration
KIMI_GPU_MEMORY_FRACTION=0.55
KIMI_KV_CACHE_SIZE_BYTES=10737418240

# Delegation Settings
KIMI_LONG_CONTEXT_THRESHOLD=8192
KIMI_ENABLE_MULTIMODAL=true
KIMI_ENABLE_AGENTIC_CODING=true
