# Project Chimera - Production Environment Variables
# Copy this file to .env and customize for PRODUCTION use
# NEVER commit actual credentials to version control

# ============================================================================
# GENERAL CONFIGURATION
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Service Version
SERVICE_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO

# Restart Policy: unless-stopped, always, on-failure
RESTART_POLICY=unless-stopped

# ============================================================================
# SECURITY CONFIGURATION (CRITICAL FOR PRODUCTION)
# ============================================================================

# CORS Configuration (comma-separated list of allowed origins)
# In production, specify exact domains only
# Example: CORS_ORIGINS=https://chimera.example.com,https://admin.chimera.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# SERVICE PORTS (INTERNAL)
# ============================================================================

OPENCLAW_ORCHESTRATOR_PORT=8000
SCENESPEAK_AGENT_PORT=8001
CAPTIONING_AGENT_PORT=8002
BSL_AGENT_PORT=8003
SENTIMENT_AGENT_PORT=8004
LIGHTING_SOUND_MUSIC_PORT=8005
SAFETY_FILTER_PORT=8006
OPERATOR_CONSOLE_PORT=8007
MUSIC_GENERATION_PORT=8011
EDUCATIONAL_PLATFORM_PORT=8012

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Neo4j Graph Database
GRAPH_DB_URL=bolt://localhost:7687
GRAPH_DB_USER=neo4j
# CHANGE THIS IN PRODUCTION
GRAPH_DB_PASSWORD=CHANGE_ME_PRODUCTION_PASSWORD

# PostgreSQL Vector Database (if using)
VECTOR_DB_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/chimera

# Redis
REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ============================================================================
# API KEYS (NEVER COMMIT TO GIT)
# ============================================================================

# OpenAI API Key
OPENAI_API_KEY=sk-...-change-me

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...-change-me

# Z.AI API Key (GLM-4.7)
ZAI_API_KEY=your-zai-api-key-here

# ============================================================================
# LLM CONFIGURATION
# ============================================================================

# Local LLM Configuration
LOCAL_LLM_ENABLED=true
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3:instruct

# Privacy Router Configuration
LOCAL_RATIO=0.95
CLOUD_FALLBACK_ENABLED=true

# Nemotron Configuration (DGX Spark)
NEMOTRON_MODEL=nemotron-8b
DGX_GPU_ID=0
DGX_ENDPOINT=http://localhost:8012

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# OpenTelemetry
OTLP_ENDPOINT=http://jaeger:4317
OTLP_PROTOCOL=grpc
TRACE_SAMPLING_RATIO=0.1

# Prometheus
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=10GB

# Grafana
GRAFANA_ADMIN_USER=admin
# CHANGE THIS IN PRODUCTION
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GRAFANA_DASHBOARDS_DIR=/etc/grafana/provisioning/dashboards

# ============================================================================
# COMMUNICATION SERVICES
# ============================================================================

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=chimera

# ============================================================================
# SAFETY & APPROVAL
# ============================================================================

# Emergency Stop Configuration
EMERGENCY_STOP_ENABLED=true
REQUIRE_HUMAN_APPROVAL=true
MAX_SCENE_DURATION_MS=600000

# ============================================================================
# TESTING & DEVELOPMENT
# ============================================================================

# Debug mode (never enable in production)
DEBUG=false

# Test mode
TEST_MODE=false
