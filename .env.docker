# Project Chimera - Docker Environment Variables
# This file contains configuration for Docker Compose orchestration

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Service Configuration
SERVICE_NAME_PREFIX=chimera
SERVICE_VERSION=1.0.0

# Infrastructure Service URLs
REDIS_URL=redis://redis:6379
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=chimera

# OpenTelemetry Configuration
OTLP_ENDPOINT=http://jaeger:4317
OTLP_PROTOCOL=grpc
TRACE_SAMPLING_RATIO=1.0

# Prometheus Configuration
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=10GB

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=chimera
GRAFANA_DASHBOARDS_DIR=/etc/grafana/provisioning/dashboards

# Core Service URLs (internal Docker networking)
OPENCLAW_ORCHESTRATOR_URL=http://openclaw-orchestrator:8000
SCENESPEAK_AGENT_URL=http://scenespeak-agent:8001
CAPTIONING_AGENT_URL=http://captioning-agent:8002
BSL_AGENT_URL=http://bsl-agent:8003
SENTIMENT_AGENT_URL=http://sentiment-agent:8004
LIGHTING_SOUND_MUSIC_URL=http://lighting-sound-music:8005
SAFETY_FILTER_URL=http://safety-filter:8006
OPERATOR_CONSOLE_URL=http://operator-console:8007

# Service Ports (internal)
OPENCLAW_ORCHESTRATOR_PORT=8000
SCENESPEAK_AGENT_PORT=8001
CAPTIONING_AGENT_PORT=8002
BSL_AGENT_PORT=8003
SENTIMENT_AGENT_PORT=8004
LIGHTING_SOUND_MUSIC_PORT=8005
SAFETY_FILTER_PORT=8006
OPERATOR_CONSOLE_PORT=8007

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# Resource Limits (production)
CPU_LIMIT_DEFAULT=1.0
MEMORY_LIMIT_DEFAULT=512M
CPU_LIMIT_AI_SERVICES=2.0
MEMORY_LIMIT_AI_SERVICES=1G

# Network Configuration
NETWORK_NAME=chimera-network
NETWORK_DRIVER=bridge

# Volume Configuration
VOLUME_REDIS_DATA=chimera-redis-data
VOLUME_KAFKA_DATA=chimera-kafka-data
VOLUME_PROMETHEUS_DATA=chimera-prometheus-data
VOLUME_GRAFANA_DATA=chimera-grafana-data

# Safety Filter Configuration
SAFETY_FILTER_POLICY=family
SAFETY_FILTER_ML_MODEL=default

# SceneSpeak Agent Configuration
SCENESPEAK_MODEL=gpt-4
SCENESPEAK_TEMPERATURE=0.7
SCENESPEAK_MAX_TOKENS=500

# Captioning Agent Configuration
CAPTIONING_LANGUAGE=en
CAPTIONING_FORMAT=srt

# BSL Agent Configuration
BSL_VIDEO_FORMAT=mp4
BSL_FRAME_RATE=30

# Sentiment Agent Configuration
SENTIMENT_MODEL=default
SENTIMENT_THRESHOLD=0.5

# Lighting/Sound/Music Configuration
LSM_DMX_PORT=0
LSM_AUDIO_OUTPUT=default

# Operator Console Configuration
OPERATOR_CONSOLE_METRICS_POLL_INTERVAL=5.0
OPERATOR_CONSOLE_ALERT_CPU_THRESHOLD=80.0
OPERATOR_CONSOLE_ALERT_MEMORY_THRESHOLD=2000.0
OPERATOR_CONSOLE_ALERT_ERROR_RATE_THRESHOLD=0.05

# Development Settings
DEV_RELOAD=true
DEV_DEBUG=false

# Docker Compose Settings
COMPOSE_PROJECT_NAME=chimera
COMPOSE_FILE=docker-compose.yml
