{
  "name": "@project-chimera/integration-tests",
  "version": "1.0.0",
  "description": "Integration tests for Project Chimera services",
  "main": "index.ts",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:ui": "playwright test --ui",
    "test:complete-show": "playwright test complete-show.spec.ts",
    "test:safety": "playwright test safety-integration.spec.ts",
    "test:bsl": "playwright test bsl-pipeline.spec.ts",
    "test:websocket": "playwright test websocket-flows.spec.ts",
    "test:show-state": "playwright test show-state.spec.ts",
    "test:all": "playwright test --project=chromium"
  },
  "keywords": [
    "integration-tests",
    "playwright",
    "testing"
  ],
  "author": "Project Chimera Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "dotenv": "^16.3.0"
  }
}
