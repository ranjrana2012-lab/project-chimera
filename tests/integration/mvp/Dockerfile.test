FROM python:3.11-slim

WORKDIR /app

# Install test dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy test files
COPY test_service_communication.py .
COPY pytest.ini .

# Set up network to communicate with services
ENV PYTHONUNBUFFERED=1

CMD ["pytest", "test_service_communication.py", "-v"]
