# Test Environment Configuration for Project Chimera
# Source this file before running tests: source tests/.test.env

# ============================================
# Application Settings
# ============================================
APP_NAME=project-chimera-test
APP_ENV=testing
APP_DEBUG=true
LOG_LEVEL=DEBUG

# ============================================
# Service Endpoints (Local Development)
# ============================================
OPENCLAW_HOST=localhost
OPENCLAW_PORT=8000

SENTIMENT_HOST=localhost
SENTIMENT_PORT=8001

SCENESPEAK_HOST=localhost
SCENESPEAK_PORT=8002

SAFETY_HOST=localhost
SAFETY_PORT=8003

CAPTIONING_HOST=localhost
CAPTIONING_PORT=8004

BSL_HOST=localhost
BSL_PORT=8005

LIGHTING_HOST=localhost
LIGHTING_PORT=8006

CONSOLE_HOST=localhost
CONSOLE_PORT=8007

# ============================================
# Infrastructure Services
# ============================================
# Redis
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
TEST_REDIS_DB=15
TEST_REDIS_PASSWORD=

# Kafka
TEST_KAFKA_SERVERS=localhost:9092
TEST_KAFKA_AVAILABLE=false

# Vector DB (Milvus)
TEST_VECTOR_DB_HOST=localhost
TEST_VECTOR_DB_PORT=19530

# ============================================
# Service Availability Flags
# ============================================
TEST_REDIS_AVAILABLE=true
TEST_KAFKA_AVAILABLE=false

# ============================================
# LLM / GPU Settings
# ============================================
LLM_MODEL_NAME=test-model
LLM_API_KEY=test-key
GPU_AVAILABLE=false
CUDA_VISIBLE_DEVICES=

# ============================================
# Test Settings
# ============================================
# pytest settings
PYTEST_ADDOPTS="-v --tb=short"
PYTEST_MARKERS="integration: integration tests"

# Coverage settings
COVERAGE_MIN=80
COVERAGE_BRANCH_MIN=70

# Load test settings
LOCUST_HOST=http://localhost:8000
LOCUST_USERS=100
LOCUST_SPAWN_RATE=10
LOCUST_RUN_TIME=5m

# ============================================
# Mock Settings
# ============================================
# Use mock services when real ones aren't available
USE_MOCK_SERVICES=false
MOCK_LLM_RESPONSES=true

# ============================================
# Timeout Settings (seconds)
# ============================================
TEST_TIMEOUT_DEFAULT=30
TEST_TIMEOUT_SENTIMENT=5
TEST_TIMEOUT_SCENESPEAK=15
TEST_TIMEOUT_SAFETY=3
TEST_TIMEOUT_BSL=10

# ============================================
# Performance Thresholds
# ============================================
MAX_LATENCY_SENTIMENT_MS=500
MAX_LATENCY_SCENESPEAK_MS=5000
MAX_LATENCY_SAFETY_MS=200
MAX_LATENCY_BSL_MS=3000

MIN_CACHE_HIT_RATIO=0.3
MAX_ERROR_RATE=0.05

# ============================================
# CI/CD Settings
# ============================================
CI=false
CI_PIPELINE_ID=
CI_BUILD_URL=

# ============================================
# Feature Flags
# ============================================
ENABLE_KAFKA_TESTS=false
ENABLE_GPU_TESTS=false
ENABLE_LOAD_TESTS=true
ENABLE_INTEGRATION_TESTS=true
