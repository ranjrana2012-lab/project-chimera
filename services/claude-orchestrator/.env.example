# Claude Code Orchestrator Environment Configuration

# Service Configuration
CLAUDE_SERVICE_NAME=claude-orchestrator
CLAUDE_PORT=8010
CLAUDE_HOST=0.0.0.0

# Nemo Claw Integration
CLAUDE_NEMOCLAW_BASE_URL=http://localhost:8000
CLAUDE_NEMOCLAW_TIMEOUT=30s

# State Persistence
CLAUDE_REDIS_URL=redis://localhost:6379
CLAUDE_STATE_DIR=/state/claude-orchestrator

# Health Monitoring
CLAUDE_HEALTH_CHECK_INTERVAL=5m
CLAUDE_HEALTH_CHECK_TIMEOUT=30s
CLAUDE_SLO_GATE_URL=http://quality-platform:9000/slo-gate

# Ralph Loop
CLAUDE_RALPH_LOOP_ENABLED=true
CLAUDE_RALPH_MAX_ITERATIONS=0

# Policy Engine
CLAUDE_POLICY_CONFIG_PATH=/config/policies.yaml
CLAUDE_POLICY_RELOAD_INTERVAL=5m

# Error Handling
CLAUDE_ERROR_RETENTION=168h
CLAUDE_ERROR_ESCALATION_TIMEOUT=5m

# Logging
CLAUDE_LOG_LEVEL=info
CLAUDE_LOG_FORMAT=json
CLAUDE_LOG_OUTPUT=stdout
