# Lighting, Sound & Music Integration Service Configuration
# Copy this file to .env and modify as needed

# ==================== ACE-Step Model Settings ====================
# DiT model path (recommended: turbo for speed)
ACESTEP_CONFIG_PATH=acestep-v15-turbo

# LM model path (used when LLM is enabled)
# Available: acestep-5Hz-lm-0.6B, acestep-5Hz-lm-1.7B, acestep-5Hz-lm-4B
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B

# Device selection: auto, cuda, cpu, xpu
ACESTEP_DEVICE=auto

# LM backend: vllm (faster) or pt (PyTorch native)
ACESTEP_LM_BACKEND=vllm

# Controls whether to initialize the Language Model
# Values: auto, true, false
ACESTEP_INIT_LLM=auto

# ==================== Download Settings ====================
# Preferred download source: auto, huggingface, modelscope
ACESTEP_DOWNLOAD_SOURCE=auto

# ==================== API Server Settings ====================
# API key for authentication (optional)
# ACESTEP_API_KEY=sk-your-secret-key

# Server port (default: 8002)
PORT=8002

# Server name/host (default: 127.0.0.1 for local only, 0.0.0.0 for network access)
SERVER_NAME=127.0.0.1

# Default batch size for generation (1 to GPU-dependent max)
ACESTEP_BATCH_SIZE=2

# ==================== Lighting Control Settings ====================
# GPIO pin for lighting control (Raspberry Pi)
LIGHTING_GPIO_PIN=18

# PWM frequency for lighting (Hz)
LIGHTING_PWM_FREQUENCY=1000

# DMX settings (for professional lighting)
DMX_ENABLED=false
DMX_PORT=/dev/ttyUSB0
DMX_CHANNELS=512

# ==================== Sound Settings ====================
# Default audio sample rate
AUDIO_SAMPLE_RATE=44100

# Default audio channels (1=mono, 2=stereo)
AUDIO_CHANNELS=2

# Audio output device (leave empty for system default)
# AUDIO_OUTPUT_DEVICE=

# ==================== Cue System Settings ====================
# Enable cue system
CUE_SYSTEM_ENABLED=true

# Cue file location
CUE_FILE_PATH=assets/cues.yaml

# ==================== Redis Settings ====================
# Redis host for caching and pub/sub
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==================== MQTT Settings ====================
# MQTT broker for IoT device communication
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ==================== Logging Settings ====================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file location (empty for stdout only)
LOG_FILE=
