# SceneSpeak Agent Configuration
# Environment variables for GLM 4.7 API integration and local LLM (Ollama) fallback

# Service Configuration
SERVICE_NAME=scenespeak-agent
PORT=8001
LOG_LEVEL=INFO

# GLM API Configuration
# Get your API key from: https://open.bigmodel.cn/
# Leave empty to use only local LLM
GLM_API_KEY=your_api_key_here
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# Local LLM Configuration (Ollama)
# Set to false to disable local LLM and use only GLM API
LOCAL_LLM_ENABLED=true
# Ollama API endpoint (default: localhost:11434)
LOCAL_LLM_URL=http://localhost:11434
# Model to use (llama3.2, mistral:7b, gemma:2b, etc.)
LOCAL_LLM_MODEL=llama3.2
# Use GLM API as fallback if local LLM fails
GLM_API_FALLBACK=true

# Legacy Configuration (deprecated)
# LOCAL_MODEL_PATH is deprecated, use LOCAL_LLM_* settings above
# LOCAL_MODEL_PATH=/path/to/local/model

# OpenTelemetry Configuration
OTLP_ENDPOINT=http://localhost:4317
