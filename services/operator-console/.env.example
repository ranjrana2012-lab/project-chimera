# Operator Console Configuration

# Service
SERVICE_NAME=operator-console
PORT=8007
LOG_LEVEL=INFO
ENVIRONMENT=development

# Service URLs (for health checks and metrics collection)
OPENCLAW_ORCHESTRATOR_URL=http://localhost:8000
SCENESPEAK_AGENT_URL=http://localhost:8001
CAPTIONING_AGENT_URL=http://localhost:8002
BSL_AGENT_URL=http://localhost:8003
SENTIMENT_AGENT_URL=http://localhost:8004
LIGHTING_SOUND_MUSIC_URL=http://localhost:8005
SAFETY_FILTER_URL=http://localhost:8006

# OpenTelemetry
OTLP_ENDPOINT=http://localhost:4317

# Metrics Collection
METRICS_POLL_INTERVAL=5.0

# Alert Thresholds
ALERT_CPU_THRESHOLD=80.0
ALERT_MEMORY_THRESHOLD=2000.0
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_REQUEST_RATE_MINIMUM=0.1
