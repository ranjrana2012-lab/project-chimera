# Safety Filter Configuration

# Service
SERVICE_NAME=safety-filter
PORT=8006
LOG_LEVEL=INFO
ENVIRONMENT=development

# Content Moderation
DEFAULT_POLICY=family
ENABLE_ML_FILTER=false
ENABLE_CONTEXT_FILTER=true
CACHE_TTL=3600

# OpenTelemetry
OTLP_ENDPOINT=http://localhost:4317

# Audit Log
AUDIT_LOG_MAX_SIZE=10000
AUDIT_LOG_RETENTION_HOURS=24
