# Educational Platform Service Environment Configuration

# Service
SERVICE_NAME=educational-platform
PORT=8012
LOG_LEVEL=INFO
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///./educational_platform.db
USE_SQLITE=true

# Integration Services
BSL_AGENT_URL=http://localhost:8003
CAPTIONING_AGENT_URL=http://localhost:8002
SENTIMENT_AGENT_URL=http://localhost:8004

# Educational Settings
DEFAULT_LEARNING_OBJECTIVES=5
MAX_ASSESSMENT_QUESTIONS=20
PASSING_SCORE_THRESHOLD=0.7
RETRY_ATTEMPTS_ALLOWED=3

# Accessibility Settings
ENABLE_BSL=true
ENABLE_CAPTIONS=true
ENABLE_SENTIMENT=true
AUTO_ADAPT_CONTENT=true

# Session Settings
SESSION_TIMEOUT_MINUTES=60
MAX_ACTIVE_SESSIONS=1000

# Analytics Settings
ANALYTICS_RETENTION_DAYS=365
ANONYMOUS_ANALYTICS=true

# OpenTelemetry
OTLP_ENDPOINT=http://localhost:4317
ENABLE_TRACING=true

# Educator Interface
EDUCATOR_DASHBOARD_ENABLED=true
CONTENT_REVIEW_REQUIRED=false
