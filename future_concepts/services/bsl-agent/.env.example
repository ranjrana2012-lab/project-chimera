# BSL Agent Configuration
# British Sign Language gloss translation service

# Service
SERVICE_NAME=bsl-agent
PORT=8003
LOG_LEVEL=INFO
ENVIRONMENT=development

# OpenTelemetry
OTLP_ENDPOINT=http://localhost:4317

# Avatar Rendering
AVATAR_MODEL_PATH=/models/bsl_avatar
AVATAR_RESOLUTION=1920x1080
AVATAR_FPS=30

# Translation
CACHE_TTL=86400
ENABLE_FACIAL_EXPRESSIONS=true
ENABLE_BODY_LANGUAGE=true
