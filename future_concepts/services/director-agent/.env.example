# Director Agent Configuration

# Logging
LOG_LEVEL=INFO

# Service Port
PORT=8013

# Agent Base URLs (override defaults if needed)
BSL_AGENT_URL=http://localhost:8003
CAPTIONING_AGENT_URL=http://localhost:8002
LIGHTING_SOUND_AGENT_URL=http://localhost:8005
SENTIMENT_AGENT_URL=http://localhost:8004
SCENESPEAK_AGENT_URL=http://localhost:8001

# Safety Settings
EMERGENCY_STOP_ENABLED=true
REQUIRE_HUMAN_APPROVAL=true
MAX_SCENE_DURATION_MS=600000

# Show Settings
SHOWS_DIR=./shows
ENABLE_SENTIMENT_ADAPTATION=false
SENTIMENT_CHECK_INTERVAL_MS=5000
