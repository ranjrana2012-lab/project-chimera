# Project Chimera - Docker Compose Environment Variables
# Copy this file to .env and customize for your environment
# This file contains all required environment variables for Docker Compose orchestration

# ============================================================================
# GENERAL CONFIGURATION
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Service Version
SERVICE_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO

# Restart Policy: unless-stopped, always, on-failure
RESTART_POLICY=unless-stopped

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# CORS Configuration (comma-separated allowed origins)
# For development, use localhost. For production, use your actual domains.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# Rate Limiting Configuration
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# Network Configuration
NETWORK_NAME=chimera-network
NETWORK_DRIVER=bridge

# Advertised Host for Kafka (use service name for Docker, localhost for local dev)
KAFKA_ADVERTISED_HOST=kafka

# ============================================================================
# GPU CONFIGURATION (for ARM64 GB10 NVIDIA DGX Spark)
# ============================================================================

# GPU Count: Number of GPUs to reserve per GPU-enabled service
# Set to 0 to disable GPU usage, 1 to use single GPU
GPU_COUNT=1

# Note: GPU-enabled services are: scenespeak-agent, captioning-agent, bsl-agent, music-generation
# For CPU-only development, set GPU_COUNT=0 and services will use CPU

# ============================================================================
# HEALTH CHECK CONFIGURATION
# ============================================================================

# Default health check settings (can be overridden per service)
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=60s

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_MAX_MEMORY=256mb

# Redis Resource Limits
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_LIMIT=256M
REDIS_CPU_RESERVATION=0.25
REDIS_MEMORY_RESERVATION=128M

# ============================================================================
# KAFKA CONFIGURATION
# ============================================================================

# Kafka
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=chimera
KAFKA_REPLICATION_FACTOR=1
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_LOG_SEGMENT_BYTES=1073741824

# Kafka Resource Limits
KAFKA_CPU_LIMIT=1.0
KAFKA_MEMORY_LIMIT=1G
KAFKA_CPU_RESERVATION=0.5
KAFKA_MEMORY_RESERVATION=512M

# ============================================================================
# ZOOKEEPER CONFIGURATION
# ============================================================================

# Zookeeper
ZOOKEEPER_PORT=2181

# Zookeeper Resource Limits
ZOOKEEPER_CPU_LIMIT=0.5
ZOOKEEPER_MEMORY_LIMIT=512M
ZOOKEEPER_CPU_RESERVATION=0.25
ZOOKEEPER_MEMORY_RESERVATION=256M

# ============================================================================
# MILVUS CONFIGURATION
# ============================================================================

# Milvus Vector Database
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
MILVUS_STORAGE_TYPE=local

# Milvus Resource Limits
MILVUS_CPU_LIMIT=2.0
MILVUS_MEMORY_LIMIT=2G
MILVUS_CPU_RESERVATION=1.0
MILVUS_MEMORY_RESERVATION=1G

# ============================================================================
# MINIO CONFIGURATION
# ============================================================================

# MinIO Object Storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# MinIO Resource Limits
MINIO_CPU_LIMIT=0.5
MINIO_MEMORY_LIMIT=512M
MINIO_CPU_RESERVATION=0.25
MINIO_MEMORY_RESERVATION=256M

# ============================================================================
# ETCD CONFIGURATION
# ============================================================================

# etcd Resource Limits
ETCD_CPU_LIMIT=0.5
ETCD_MEMORY_LIMIT=512M
ETCD_CPU_RESERVATION=0.25
ETCD_MEMORY_RESERVATION=256M

# ============================================================================
# PROMETHEUS CONFIGURATION
# ============================================================================

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=15d

# Prometheus Resource Limits
PROMETHEUS_CPU_LIMIT=1.0
PROMETHEUS_MEMORY_LIMIT=1G
PROMETHEUS_CPU_RESERVATION=0.5
PROMETHEUS_MEMORY_RESERVATION=512M

# ============================================================================
# JAEGER CONFIGURATION
# ============================================================================

# Jaeger Tracing
JAEGER_PORT_UDP=5775
JAEGER_PORT_UDP2=6831
JAEGER_PORT_UDP3=6832
JAEGER_PORT_HTTP=5778
JAEGER_PORT_UI=16686
JAEGER_PORT_THRIFT=14268
JAEGER_PORT_GRPC=14250
JAEGER_PORT_ZIPKIN=9411
JAEGER_PORT_OTLP_GRPC=4317
JAEGER_PORT_OTLP_HTTP=4318
JAEGER_STORAGE_TYPE=memory

# OpenTelemetry Configuration
OTLP_ENDPOINT=http://jaeger:4317
OTLP_PROTOCOL=grpc
TRACE_SAMPLING_RATIO=1.0

# Jaeger Resource Limits
JAEGER_CPU_LIMIT=1.0
JAEGER_MEMORY_LIMIT=1G
JAEGER_CPU_RESERVATION=0.5
JAEGER_MEMORY_RESERVATION=512M

# ============================================================================
# GRAFANA CONFIGURATION
# ============================================================================

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=chimera
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_PLUGINS=

# Grafana Resource Limits
GRAFANA_CPU_LIMIT=0.5
GRAFANA_MEMORY_LIMIT=512M
GRAFANA_CPU_RESERVATION=0.25
GRAFANA_MEMORY_RESERVATION=256M

# ============================================================================
# NETDATA CONFIGURATION
# ============================================================================

# Netdata Real-time Monitoring
NETDATA_PORT=19999
NETDATA_CLAIM_TOKEN=
NETDATA_CLAIM_URL=
NETDATA_CLAIM_ROOMS=
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#chimera-alerts
SLACK_CRITICAL_CHANNEL=#chimera-critical

# Netdata Resource Limits
NETDATA_CPU_LIMIT=0.5
NETDATA_MEMORY_LIMIT=512M
NETDATA_CPU_RESERVATION=0.1
NETDATA_MEMORY_RESERVATION=128M

# Alert Notification Settings
NORMAL_NOTIFICATION_DELAY=60
CRITICAL_NOTIFICATION_DELAY=10
MAX_NOTIFICATIONS_PER_HOUR=10
CRITICAL_REPEAT_INTERVAL=10
WARNING_REPEAT_INTERVAL=30
ERROR_REPEAT_INTERVAL=30

# ============================================================================
# SERVICE INTERNAL URLs (Docker Networking)
# ============================================================================

# Core Service URLs (internal Docker networking)
OPENCLAW_ORCHESTRATOR_URL=http://openclaw-orchestrator:8000
SCENESPEAK_AGENT_URL=http://scenespeak-agent:8001
CAPTIONING_AGENT_URL=http://captioning-agent:8002
BSL_AGENT_URL=http://bsl-agent:8003
SENTIMENT_AGENT_URL=http://sentiment-agent:8004
LIGHTING_SOUND_MUSIC_URL=http://lighting-sound-music:8005
SAFETY_FILTER_URL=http://safety-filter:8006
OPERATOR_CONSOLE_URL=http://operator-console:8007
MUSIC_GENERATION_URL=http://music-generation:8011
HEALTH_AGGREGATOR_URL=http://health-aggregator:8012

# ============================================================================
# SERVICE PORTS
# ============================================================================

# Service Ports (internal)
OPENCLAW_ORCHESTRATOR_PORT=8000
SCENESPEAK_AGENT_PORT=8001
CAPTIONING_AGENT_PORT=8002
BSL_AGENT_PORT=8003
SENTIMENT_AGENT_PORT=8004
LIGHTING_SOUND_MUSIC_PORT=8005
SAFETY_FILTER_PORT=8006
OPERATOR_CONSOLE_PORT=8007
MUSIC_GENERATION_PORT=8011
HEALTH_AGGREGATOR_PORT=8012
DASHBOARD_PORT=8013

# ============================================================================
# SERVICE RESOURCE LIMITS
# ============================================================================

# OpenClaw Orchestrator
OPENCLAW_CPU_LIMIT=1.0
OPENCLAW_MEMORY_LIMIT=512M
OPENCLAW_CPU_RESERVATION=0.25
OPENCLAW_MEMORY_RESERVATION=128M
OPENCLAW_REPLICAS=1

# SceneSpeak Agent (GPU-enabled)
SCENESPEAK_CPU_LIMIT=2.0
SCENESPEAK_MEMORY_LIMIT=1G
SCENESPEAK_CPU_RESERVATION=0.5
SCENESPEAK_MEMORY_RESERVATION=256M
SCENESPEAK_REPLICAS=1

# Captioning Agent (GPU-enabled)
CAPTIONING_CPU_LIMIT=2.0
CAPTIONING_MEMORY_LIMIT=1G
CAPTIONING_CPU_RESERVATION=0.5
CAPTIONING_MEMORY_RESERVATION=256M
CAPTIONING_REPLICAS=1

# BSL Agent (GPU-enabled)
BSL_CPU_LIMIT=2.0
BSL_MEMORY_LIMIT=1G
BSL_CPU_RESERVATION=0.5
BSL_MEMORY_RESERVATION=256M
BSL_REPLICAS=1

# Sentiment Agent
SENTIMENT_CPU_LIMIT=1.0
SENTIMENT_MEMORY_LIMIT=512M
SENTIMENT_CPU_RESERVATION=0.25
SENTIMENT_MEMORY_RESERVATION=128M
SENTIMENT_REPLICAS=1

# Lighting-Sound-Music
LSM_CPU_LIMIT=1.0
LSM_MEMORY_LIMIT=512M
LSM_CPU_RESERVATION=0.25
LSM_MEMORY_RESERVATION=128M
LSM_REPLICAS=1

# Safety Filter
SAFETY_CPU_LIMIT=2.0
SAFETY_MEMORY_LIMIT=1G
SAFETY_CPU_RESERVATION=0.5
SAFETY_MEMORY_RESERVATION=256M
SAFETY_REPLICAS=1

# Operator Console
CONSOLE_CPU_LIMIT=0.5
CONSOLE_MEMORY_LIMIT=256M
CONSOLE_CPU_RESERVATION=0.25
CONSOLE_MEMORY_RESERVATION=128M
CONSOLE_REPLICAS=1

# Music Generation (GPU-enabled)
MUSIC_CPU_LIMIT=2.0
MUSIC_MEMORY_LIMIT=2G
MUSIC_CPU_RESERVATION=0.5
MUSIC_MEMORY_RESERVATION=512M
MUSIC_REPLICAS=1

# Health Aggregator
HEALTH_AGGREGATOR_CPU_LIMIT=0.5
HEALTH_AGGREGATOR_MEMORY_LIMIT=256M
HEALTH_AGGREGATOR_CPU_RESERVATION=0.1
HEALTH_AGGREGATOR_MEMORY_RESERVATION=64M

# Dashboard
DASHBOARD_CPU_LIMIT=0.5
DASHBOARD_MEMORY_LIMIT=256M
DASHBOARD_CPU_RESERVATION=0.1
DASHBOARD_MEMORY_RESERVATION=64M

# ============================================================================
# SERVICE-SPECIFIC CONFIGURATION
# ============================================================================

# SceneSpeak Agent Configuration
SCENESPEAK_LOCAL_LLM_ENABLED=true
SCENESPEAK_LOCAL_LLM_URL=http://ollama:11434
SCENESPEAK_LOCAL_LLM_MODEL=llama3.2
SCENESPEAK_GLM_API_KEY=
SCENESPEAK_GLM_API_FALLBACK=true

# Captioning Agent Configuration
CAPTIONING_MODEL_SIZE=base
CAPTIONING_DEVICE=cuda
CAPTIONING_COMPUTE_TYPE=float16
CAPTIONING_MAX_FILE_SIZE=26214400

# BSL Agent Configuration
BSL_AVATAR_MODEL_PATH=/models/bsl_avatar
BSL_AVATAR_RESOLUTION=1920x1080
BSL_AVATAR_FPS=30
BSL_CACHE_TTL=86400

# Sentiment Agent Configuration
SENTIMENT_MODEL=default
SENTIMENT_THRESHOLD=0.5

# Safety Filter Configuration
SAFETY_FILTER_POLICY=family
SAFETY_FILTER_ML_MODEL=default

# Lighting-Sound-Music Configuration
LSM_DMX_PORT=0
LSM_AUDIO_OUTPUT=default

# Music Generation Configuration
MUSICGEN_MODEL_PATH=/models/musicgen
ACESTEP_MODEL_PATH=/models/acestep
HUGGINGFACE_CACHE_DIR=/models/cache
MUSIC_DEFAULT_MODEL=musicgen
MUSIC_MAX_VRAM_MB=8192
MUSIC_MODEL_OFFLOAD=true
MUSIC_DEFAULT_DURATION=5.0
MUSIC_MAX_DURATION=30.0
MUSIC_SAMPLE_RATE=44100
MUSIC_DEVICE=cuda
MUSIC_TORCH_THREADS=4

# Health Aggregator Configuration
HEALTH_POLL_INTERVAL=30
HEALTH_TIMEOUT=5

# Dashboard Configuration
PROJECT_ROOT=/home/ranj/Project_Chimera

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Development Settings
DEV_RELOAD=true
DEV_DEBUG=false

# ============================================================================
# DOCKER COMPOSE SETTINGS
# ============================================================================

# Docker Compose Settings
COMPOSE_PROJECT_NAME=chimera
COMPOSE_FILE=docker-compose.yml

# ============================================================================
# VOLUME CONFIGURATION
# ============================================================================

# Volume Configuration
VOLUME_REDIS_DATA=chimera-redis-data
VOLUME_KAFKA_DATA=chimera-kafka-data
VOLUME_PROMETHEUS_DATA=chimera-prometheus-data
VOLUME_GRAFANA_DATA=chimera-grafana-data
