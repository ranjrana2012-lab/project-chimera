# Project Chimera - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Application Configuration
# ============================================
APP_NAME="project-chimera"
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_PREFIX=/api/v1

# ============================================
# Service Configuration
# ============================================
# OpenClaw Orchestrator
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=8000
OPENCLAW_GPU_ENABLED=true
OPENCLAW_MODEL_CACHE_PATH=/app/models

# SceneSpeak Agent
SCENESPEAK_HOST=0.0.0.0
SCENESPEAK_PORT=8001
SCENESPEAK_MODEL_PATH=/app/models/llama-2-7b
SCENESPEAK_CACHE_ENABLED=true
SCENESPEAK_MAX_TOKENS=512
SCENESPEAK_TEMPERATURE=0.8

# Captioning Agent
CAPTIONING_HOST=0.0.0.0
CAPTIONING_PORT=8002
CAPTIONING_WHISPER_MODEL=base
CAPTIONING_LANGUAGE=en

# BSL-Text2Gloss Agent
BSL_TEXT2GLOSS_HOST=0.0.0.0
BSL_TEXT2GLOSS_PORT=8003

# Sentiment Agent
SENTIMENT_HOST=0.0.0.0
SENTIMENT_PORT=8004
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment

# Lighting Control
LIGHTING_HOST=0.0.0.0
LIGHTING_PORT=8005
LIGHTING_DMX_HOST=192.168.1.100
LIGHTING_DMX_PORT=6454
LIGHTING_OSC_HOST=127.0.0.1
LIGHTING_OSC_PORT=9000

# Safety Filter
SAFETY_HOST=0.0.0.0
SAFETY_PORT=8006
SAFETY_REVIEW_QUEUE_SIZE=1000

# Operator Console
OPERATOR_HOST=0.0.0.0
OPERATOR_PORT=8007

# ============================================
# Storage Configuration
# ============================================
# Redis
REDIS_HOST=redis.shared.svc.cluster.local
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka.shared.svc.cluster.local:9092
KAFKA_CONSUMER_GROUP=project-chimera
KAFKA_AUTO_OFFSET_RESET=latest

# Vector Database
VECTOR_DB_HOST=vector-db.shared.svc.cluster.local
VECTOR_DB_PORT=19530
VECTOR_DB_INDEX=chimera-skills

# ============================================
# Kubernetes Configuration
# ============================================
K8S_NAMESPACE=live
K8S_SHARED_NAMESPACE=shared
K8S_STORAGE_CLASS=shared-nfs
K8S_IMAGE_PULL_POLICY=IfNotPresent

# ============================================
# Monitoring Configuration
# ============================================
# Prometheus
PROMETHEUS_HOST=prometheus.shared.svc.cluster.local
PROMETHEUS_PORT=9090
METRICS_PATH=/metrics
METRICS_ENABLED=true

# Jaeger Tracing
JAEGER_HOST=jaeger.shared.svc.cluster.local
JAEGER_PORT=6831
TRACING_ENABLED=true

# Grafana
GRAFANA_HOST=grafana.shared.svc.cluster.local
GRAFANA_PORT=3000

# ============================================
# Security Configuration
# ============================================
SECRET_KEY=change-me-in-production-use-sealed-secrets
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# API Keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# Feature Flags
# ============================================
FEATURE_SCENESPEAK_ENABLED=true
FEATURE_CAPTIONING_ENABLED=true
FEATURE_BSL_ENABLED=true
FEATURE_SENTIMENT_ENABLED=true
FEATURE_LIGHTING_ENABLED=true
FEATURE_SAFETY_FILTER_ENABLED=true
FEATURE_OPERATOR_CONSOLE_ENABLED=true

# ============================================
# Development Settings
# ============================================
DEV_LOG_LEVEL=DEBUG
DEV_RELOAD=true
DEV_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
